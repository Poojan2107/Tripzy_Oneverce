# ============================================================
# Tripzy / Travebie — Environment Template
# Copy to `.env` and fill in real values. Never commit `.env`.
# Dev server runs on port 3030: http://localhost:3030
# ============================================================

# --- REQUIRED ---

# Neon PostgreSQL (pooled connection string for Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Google Gemini AI (either name works; prefer GOOGLE_GENERATIVE_AI_API_KEY)
GOOGLE_GENERATIVE_AI_API_KEY="your_gemini_api_key_here"
# GEMINI_API_KEY="your_gemini_api_key_here"

# NextAuth — local MUST use port 3030 (matches `npm run dev`)
NEXTAUTH_URL="http://localhost:3030"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_SECRET="same-value-as-AUTH_SECRET"

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Local origins:  http://localhost:3030
# Local redirect: http://localhost:3030/api/auth/callback/google
# Prod origins:   https://tripzy-oneverce.vercel.app
# Prod redirect:  https://tripzy-oneverce.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"

# Admin promotion key (≥16 chars). Used at /admin/setup
ADMIN_SETUP_KEY="replace-with-long-random-secret"

# Canonical public URL (sitemap, metadata, CORS). Prod example:
# NEXT_PUBLIC_BASE_URL="https://tripzy-oneverce.vercel.app"
NEXT_PUBLIC_BASE_URL="http://localhost:3030"

# --- RECOMMENDED (admin image upload) ---

# UploadThing — https://uploadthing.com/dashboard
# Without these, admin can still paste image URLs manually.
UPLOADTHING_TOKEN=""
# UPLOADTHING_SECRET=""
# UPLOADTHING_APP_ID=""

# --- OPTIONAL ---

# Upstash Redis — API rate limiting (fails open if unset)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Sentry — error monitoring
# SENTRY_DSN="https://your-dsn.sentry.io"
# NEXT_PUBLIC_SENTRY_DSN="https://your-dsn.sentry.io"
# SENTRY_ORG="your-org"
# SENTRY_PROJECT="your-project"
# SENTRY_AUTH_TOKEN="your-auth-token"

# Rate limiting defaults
# RATE_LIMIT_REQUESTS="20"
# RATE_LIMIT_WINDOW="10 s"

# Keep false in production. Never enable on Vercel.
TESTING_MODE="false"

# Seed safety — required only when running `npm run db:seed` (WIPES data)
# ALLOW_DB_WIPE="true"
