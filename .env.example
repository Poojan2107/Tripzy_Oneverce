# Database — PostgreSQL (Neon) or SQLite for local dev
DATABASE_URL="file:./dev.db"

# Gemini AI
GOOGLE_GENERATIVE_AI_API_KEY="your_gemini_api_key_here"

# Upstash Redis (optional — enables API rate limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="your-client-secret"

# NextAuth — required for auth to work
# NEXTAUTH_URL="http://localhost:3000"
# AUTH_SECRET="generate-a-random-secret-here"
# NEXTAUTH_SECRET="same-as-auth-secret"

# Admin setup key — used to promote users to ADMIN
# ADMIN_SETUP_KEY="your-uuid-here"

# Testing mode
# TESTING_MODE="false"

# Sentry — error monitoring (optional)
# SENTRY_DSN="https://your-dsn.sentry.io"
# NEXT_PUBLIC_SENTRY_DSN="https://your-dsn.sentry.io"
# SENTRY_ORG="your-org"
# SENTRY_PROJECT="your-project"
# SENTRY_AUTH_TOKEN="your-auth-token"

# Base URL (overrides auto-detection for sitemap/metadata)
# NEXT_PUBLIC_BASE_URL="https://yourdomain.com"

# Rate limiting (optional — defaults to 20 requests per 10s window)
# RATE_LIMIT_REQUESTS="20"
# RATE_LIMIT_WINDOW="10 s"

# Seed safety — set to "true" to allow prisma seed to wipe existing data
# ALLOW_DB_WIPE="true"
