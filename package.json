{
  "name": "travebie",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --port=3030 --hostname 0.0.0.0",
    "build": "next build && node scripts/postbuild.mjs",
    "start": "next start --port=3030",
    "lint": "next typegen && tsc --noEmit",
    "typecheck": "next typegen && tsc --noEmit",
    "prebuild": "node scripts/check-env.mjs",
    "postinstall": "sh -c 'DATABASE_URL=${DATABASE_URL:-postgresql://dummy:dummy@localhost:5432/dummy} prisma generate'",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "analyze": "cross-env ANALYZE=true npm run build"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@google/genai": "^2.4.0",
    "@prisma/client": "^6.19.3",
    "@sentry/nextjs": "^10.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@uploadthing/react": "^7.3.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "ai": "^6.0.198",
    "framer-motion": "^12.41.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "next": "^16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "prisma": "^6.19.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "recharts": "^3.9.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "uploadthing": "^7.7.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.14.0",
    "@types/react": "19.2.17",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vitest": "^4.1.9"
  }
}
